# CAIP Sandbox Demo — LLM Configuration
#
# Choose your LLM provider and set the API key.

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# To use OpenAI instead, uncomment below and comment out the Anthropic lines:
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
